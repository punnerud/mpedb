# Expression evaluation: precedence, integer vs float arithmetic, the
# int64 -> float64 coercion, constant folding (fold-time results match
# runtime results exactly), division-by-zero as NULL (sqlite semantics),
# overflow as an error (sqlite would wrap), and predicate typing.
#
# schema:
# [[table]]
# name = "t"
# primary_key = ["id"]
#
#   [[table.column]]
#   name = "id"
#   type = "int64"
#
#   [[table.column]]
#   name = "a"
#   type = "int64"
#
#   [[table.column]]
#   name = "f"
#   type = "float64"
# end schema

statement ok
INSERT INTO t (id, a, f) VALUES (1, 5, 2.25)

statement ok
INSERT INTO t (id, a, f) VALUES (2, NULL, NULL)

# ---- precedence and associativity --------------------------------------------------

query I nosort
SELECT 1 + 2 * 3 FROM t WHERE id = 1
----
7

query I nosort
SELECT (1 + 2) * 3 FROM t WHERE id = 1
----
9

query I nosort
SELECT -2 * 3 FROM t WHERE id = 1
----
-6

query I nosort
SELECT 7 - 4 - 2 FROM t WHERE id = 1
----
1

query I nosort
SELECT 2 * 3 + 4 * 5 FROM t WHERE id = 1
----
26

query I nosort
SELECT 3 % 2 * 2 FROM t WHERE id = 1
----
2

query I nosort
SELECT 10 / 3 / 2 FROM t WHERE id = 1
----
1

query I nosort
SELECT -(-5) FROM t WHERE id = 1
----
5

query I nosort
SELECT a - -1 FROM t WHERE id = 1
----
6

# ---- integer arithmetic truncates toward zero ---------------------------------------

query I nosort
SELECT 7 / 2 FROM t WHERE id = 1
----
3

query I nosort
SELECT -7 / 2 FROM t WHERE id = 1
----
-3

query I nosort
SELECT 7 % 3 FROM t WHERE id = 1
----
1

query I nosort
SELECT -7 % 3 FROM t WHERE id = 1
----
-1

# ---- float arithmetic and the one coercion -------------------------------------------

query R nosort
SELECT 1 / 2.0 FROM t WHERE id = 1
----
0.500

query R nosort
SELECT 1.5 * 2 FROM t WHERE id = 1
----
3.000

query R nosort
SELECT 7.5 % 2.0 FROM t WHERE id = 1
----
1.500

query R nosort
SELECT a + 1.5 FROM t
----
6.500
NULL

query R nosort
SELECT f * 2 FROM t WHERE id = 1
----
4.500

query I nosort
SELECT id FROM t WHERE a < 5.5
----
1

# ---- comparisons and boolean logic fold ----------------------------------------------

query T nosort
SELECT 1 < 2 FROM t WHERE id = 1
----
true

query T nosort
SELECT 1 >= 2 FROM t WHERE id = 1
----
false

query T nosort
SELECT 'a' < 'b' FROM t WHERE id = 1
----
true

query T nosort
SELECT true AND false FROM t WHERE id = 1
----
false

query T nosort
SELECT NOT true FROM t WHERE id = 1
----
false

# ---- division by zero is NULL; overflow is an error (fold-time and runtime agree) ----

# sqlite yields NULL on division / modulo by zero, not an error. Both rows of
# t produce NULL (the divisor is the constant 0, folded before the scan).
query I nosort
SELECT 1 / 0 FROM t
----
NULL
NULL

query I nosort
SELECT 1 % 0 FROM t
----
NULL
NULL

# Overflow, in contrast, still raises.
statement error overflow
SELECT 9223372036854775807 + 1 FROM t

# The same results surface at runtime when the values come from rows.
# a / (a - a) is 5 / 0 -> NULL for id = 1.
query I nosort
SELECT a / (a - a) FROM t WHERE id = 1
----
NULL

statement error overflow
SELECT a * 9223372036854775807 FROM t WHERE id = 1

# ---- predicates in WHERE ---------------------------------------------------------------

query I nosort
SELECT id FROM t WHERE a * 2 = 10
----
1

query I nosort
SELECT id FROM t WHERE (a + 1) * 2 >= 12
----
1

# NOT(UNKNOWN) is UNKNOWN: the NULL row never matches.
query I nosort
SELECT id FROM t WHERE NOT (a = 5)
----

# A non-boolean predicate is truthy-tested exactly as sqlite does: the value is
# TRUE iff its REAL value is non-zero (`sqlite3VdbeBooleanValue`), NULL stays
# unknown. Row 1 has a = 5, row 2 has a = NULL.
query I nosort
SELECT id FROM t WHERE a + 1
----
1

# a - 5 is 0 for row 1 and NULL for row 2: neither row passes.
query I nosort
SELECT id FROM t WHERE a - 5
----

query I nosort
SELECT id FROM t WHERE f
----
1

query I nosort
SELECT id FROM t WHERE NOT a
----

query T nosort
SELECT CASE WHEN a THEN 'T' ELSE 'F' END FROM t
----
T
F

# Comparisons do not chain.
statement error parse error
SELECT id FROM t WHERE 1 < a < 10

# ---- CAST: NULL-safe, truncating, sqlite affinity-based -------------------------------

# NULL casts to NULL of any type — the corpus' favourite CAST.
query I nosort
SELECT CAST(NULL AS INTEGER) FROM t WHERE id = 1
----
NULL

# float -> int truncates toward zero (sqlite's rule).
query I nosort
SELECT CAST(f AS INTEGER) FROM t WHERE id = 1
----
2

query I nosort
SELECT CAST(-1.9 AS INTEGER) FROM t WHERE id = 1
----
-1

query R nosort
SELECT CAST(a AS REAL) FROM t WHERE id = 1
----
5.000

# a NULL column value passes through regardless of target type
query I nosort
SELECT CAST(f AS INTEGER) FROM t WHERE id = 2
----
NULL

query T nosort
SELECT CAST(a AS TEXT) FROM t WHERE id = 1
----
5

# sqlite affinity: any type name is accepted and text parses its leading
# numeric prefix. `'12ab'` -> 12 (INTEGER stops at the first non-digit).
query I nosort
SELECT CAST('12ab' AS INTEGER) FROM t WHERE id = 1
----
12

# An unknown target name resolves by sqlite's substring rule: SIGNED/DECIMAL
# -> NUMERIC affinity, which is INTEGER when the value is integral.
query I nosort
SELECT CAST(a AS SIGNED) FROM t WHERE id = 1
----
5

# VARCHAR(n) -> TEXT affinity; the size is ignored. Real renders via %!.15g.
query T nosort
SELECT CAST(f AS VARCHAR(10)) FROM t WHERE id = 1
----
2.25

# ---- || concatenation (#56) ------------------------------------------------------------

query T nosort
SELECT 'a' || 'b' || 'c' FROM t WHERE id = 1
----
abc

# ints render as text (sqlite's rule); NULL propagates.
query T nosort
SELECT 'a=' || a FROM t ORDER BY id
----
a=5
NULL

# floats are refused until their text formatting is pinned down.
statement error requires text, int64, or bool
SELECT 'f=' || f FROM t

# lone | is a parse error, not a mystery token
statement error parse error
SELECT 'a' | 'b' FROM t
