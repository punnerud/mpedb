# INNER JOIN of two tables in one file.
#
# Expected values come from running the same program through sqlite3 3.45.
#
# The thing to hold onto: an INNER JOIN emits a row only where BOTH sides
# match. So `dee` (whose did is NULL) never appears, and the 'empty' dept
# never appears — a NULL never equals anything, including another NULL, and a
# dept with no employees has nothing to pair with. Neither is a special case;
# both fall out of the ON condition being a plain 3VL predicate.
#
# Output columns are qualified `<table>.<column>` because `did` alone would
# not say which side it came from, and both sides have one.
#
# schema:
# [[table]]
# name = "dept"
# primary_key = ["did"]
#
#   [[table.column]]
#   name = "did"
#   type = "int64"
#
#   [[table.column]]
#   name = "dname"
#   type = "text"
#
# [[table]]
# name = "emp"
# primary_key = ["eid"]
#
#   [[table.column]]
#   name = "eid"
#   type = "int64"
#
#   [[table.column]]
#   name = "ename"
#   type = "text"
#
#   [[table.column]]
#   name = "did"
#   type = "int64"
#   nullable = true
# end schema

statement ok
INSERT INTO dept (did, dname) VALUES (1, 'eng'), (2, 'sales'), (3, 'empty')

statement ok
INSERT INTO emp (eid, ename, did) VALUES (10, 'ann', 1), (11, 'bob', 1), (12, 'cy', 2)

# `dee` has no department.
statement ok
INSERT INTO emp (eid, ename, did) VALUES (13, 'dee', NULL)

# ---- the basic shape ----------------------------------------------------------------

query TT nosort
SELECT emp.ename, dept.dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY emp.eid
----
ann
eng
bob
eng
cy
sales

# Unqualified names resolve when they are unambiguous. `did` would NOT be —
# both tables have it — and that is an error rather than a silent pick.
query TT nosort
SELECT ename, dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY eid
----
ann
eng
bob
eng
cy
sales

statement error ambiguous
SELECT did FROM emp JOIN dept ON emp.did = dept.did

# INNER is the default; spelling it changes nothing.
query TT nosort
SELECT emp.ename, dept.dname FROM emp INNER JOIN dept ON emp.did = dept.did ORDER BY emp.eid
----
ann
eng
bob
eng
cy
sales

# ---- what an INNER JOIN drops -------------------------------------------------------
# 4 employees and 3 departments, but only 3 rows: `dee` has a NULL did (NULL
# equals nothing, not even NULL), and 'empty' has nobody to pair with.

query T nosort
SELECT dept.dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY dept.dname
----
eng
eng
sales

# ---- WHERE, over the joined row -----------------------------------------------------

query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did WHERE dept.dname = 'eng' ORDER BY emp.eid
----
ann
bob

# `IS NOT NULL` on the join column is redundant — the ON already dropped the
# NULL row, because NULL = anything is NULL and not TRUE. Pinned so that the
# day someone "optimizes" NULL handling in the ON, this says what changed.
query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did WHERE emp.did IS NOT NULL ORDER BY emp.eid
----
ann
bob
cy

# ---- ON is a predicate, not just an equality ----------------------------------------

query II nosort
SELECT emp.eid, dept.did FROM emp JOIN dept ON emp.did > dept.did ORDER BY emp.eid, dept.did
----
12
1

# An ON that ignores the outer row entirely: every surviving outer row pairs
# with the one matching dept. This is legal, and it is why ON is required —
# leaving it out would silently mean this.
query TT nosort
SELECT emp.ename, dept.dname FROM emp JOIN dept ON dept.did = 1 ORDER BY emp.eid, dept.dname
----
ann
eng
bob
eng
cy
eng
dee
eng

# ---- the rest of the surface still applies ------------------------------------------

query T nosort
SELECT DISTINCT dept.dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY dept.dname
----
eng
sales

# DISTINCT + LIMIT bounds DISTINCT rows, never pre-dedup joined duplicates:
# eng appears twice in the join, and a LIMIT that counted duplicates returned
# ONE distinct row here instead of two (adversarial review find; verified
# against sqlite3, which returns both).
query T nosort
SELECT DISTINCT dept.dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY dept.dname LIMIT 2
----
eng
sales

# ... and OFFSET consumes a DISTINCT row, not a duplicate.
query T nosort
SELECT DISTINCT dept.dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY dept.dname LIMIT 5 OFFSET 1
----
sales

# Under DISTINCT the sort key must be in the SELECT list — over a join too.
# The single-table path has refused this all along; the join path let it
# through and deduped on the invisible sort value, returning duplicates.
statement error must be in the SELECT list
SELECT DISTINCT dept.dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY emp.eid + 1

# LIMIT bounds JOINED rows, not outer rows.
query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did ORDER BY emp.eid LIMIT 2 OFFSET 1
----
bob
cy

# `SELECT *` is every column of both sides, outer first — the order the tuple
# is built in.
query ITIIT nosort
SELECT * FROM emp JOIN dept ON emp.did = dept.did ORDER BY emp.eid
----
10
ann
1
1
eng
11
bob
1
1
eng
12
cy
2
2
sales

query TI nosort
SELECT emp.ename, dept.did * 10 FROM emp JOIN dept ON emp.did = dept.did ORDER BY emp.eid
----
ann
10
bob
10
cy
20

# Sorting by a column of the INNER table, which the query does not output —
# the sort-only column machinery reaches across the join too.
query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did ORDER BY dept.dname, emp.ename
----
ann
bob
cy

# The whole expression surface works over the joined row — it is one tuple,
# just wider.

query TT nosort
SELECT emp.ename, CASE WHEN dept.did = 1 THEN 'core' ELSE 'other' END FROM emp JOIN dept ON emp.did = dept.did ORDER BY emp.eid
----
ann
core
bob
core
cy
other

query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did WHERE dept.dname IN ('eng', 'zzz') ORDER BY emp.eid
----
ann
bob

query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did WHERE dept.dname LIKE 'e%' ORDER BY emp.eid
----
ann
bob

# The same column name from both sides, side by side — this is what the
# qualifier is for.
query II nosort
SELECT emp.did, dept.did FROM emp JOIN dept ON emp.did = dept.did ORDER BY emp.eid
----
1
1
1
1
2
2

# An ON with more than one conjunct.
query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did AND dept.dname = 'eng' ORDER BY emp.eid
----
ann
bob

# The comma-join (#56): `FROM a, b` IS the cartesian product, filtered by
# WHERE — desugared to INNER JOIN ON true. Same answer as the basic shape.
query TT nosort
SELECT emp.ename, dept.dname FROM emp, dept WHERE emp.did = dept.did ORDER BY emp.eid
----
ann
eng
bob
eng
cy
sales

query I nosort
SELECT count(*) FROM emp, dept
----
12

# Mixing comma and keyword joins is legal; the comma pairs first.
query I nosort
SELECT count(*) FROM emp, dept d2 JOIN dept d3 ON d3.did = 1
----
12

# SELECT-item aliases (#56) name the output and resolve in ORDER BY.
query IT nosort
SELECT emp.eid AS e, dept.dname nm FROM emp JOIN dept ON emp.did = dept.did ORDER BY e LIMIT 2
----
10
eng
11
eng

# ORDER BY an ordinal, over a join.
query TT nosort
SELECT emp.ename, dept.dname FROM emp JOIN dept ON emp.did = dept.did ORDER BY 2, 1
----
ann
eng
bob
eng
cy
sales

# ORDER BY a computed key over the INNER table, output by neither — a
# sort-only column reaching across the join.
query T nosort
SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did ORDER BY dept.did * -1, emp.eid
----
cy
ann
bob

# ---- what is refused, and why -------------------------------------------------------

# A self-join WITHOUT aliases has no way to tell the two sides apart, so `emp.eid`
# would be ambiguous. Refused — but with aliases it is allowed (below).
statement error used for two tables
SELECT emp.eid FROM emp JOIN emp ON emp.eid = emp.eid

# A self-join WITH distinct aliases (#44): pair employees in the same department.
# ann and bob are both in dept 1; cy is alone in dept 2; dee has a NULL did and
# matches nobody. Same answer as sqlite3.
query TT rowsort
SELECT a.ename, b.ename FROM emp a JOIN emp b ON a.did = b.did AND a.eid < b.eid
----
ann
bob

# A 3-table chain (#45), left-deep, mixing a real table and a self-join:
# ann is in eng (dept 1); the third join finds everyone ELSE in eng. Same
# answer as sqlite3, which is the whole point of this file.
query TTT rowsort
SELECT e.ename, d.dname, e2.ename
FROM emp e
JOIN dept d ON e.did = d.did
JOIN emp e2 ON e2.did = d.did
WHERE e.eid = 10
----
ann
eng
ann
ann
eng
bob

# ON is required. A comma-join is a cartesian product, and the times someone
# means one are far outnumbered by the times they forgot the condition.
statement error ON after JOIN
SELECT emp.eid FROM emp JOIN dept

# A LEFT JOIN keeps rows with no match and NULL-extends the inner side (#46):
# dee (NULL did) comes back with a NULL department instead of vanishing. Same
# answer as sqlite3. The full LEFT corpus lives in left_join.test.
query IT nosort
SELECT emp.eid, dept.dname FROM emp LEFT JOIN dept ON emp.did = dept.did ORDER BY emp.eid
----
10
eng
11
eng
12
sales
13
NULL

# LEFT OUTER JOIN is the same join — OUTER is noise the standard permits.
query I nosort
SELECT count(*) FROM emp LEFT OUTER JOIN dept ON emp.did = dept.did
----
4

# RIGHT/FULL keep rows the other way (or both ways) and stay refused by NAME —
# RIGHT plans as LEFT with the sides swapped (#64): all dept rows survive,
# the empty dept NULL-extends emp's columns.
query I nosort
SELECT emp.eid FROM emp RIGHT JOIN dept ON emp.did = dept.did ORDER BY 1
----
NULL
10
11
12

# FULL keeps unmatched rows from BOTH sides (#64).
query I nosort
SELECT count(*) FROM emp FULL OUTER JOIN dept ON emp.did = dept.did
----
5

# CROSS JOIN is the cartesian product, same desugar as the comma-join (#56).
query I nosort
SELECT count(*) FROM emp CROSS JOIN dept
----
12

# A qualifier that names no table in the statement is a typo, not a hint.
statement error no table named
SELECT nonsense.eid FROM emp JOIN dept ON emp.did = dept.did

# ---- aggregates, over the joined row ------------------------------------------------
# Nothing in the grouping step is about tables — it is about the row it is
# handed. So the same planner runs; the row is just wider.

query I nosort
SELECT count(*) FROM emp JOIN dept ON emp.did = dept.did
----
3

# The 'empty' dept has no employees, so it is not a group with count 0 — it is
# not a group at all. That is the INNER JOIN, not the aggregate.
query TI nosort
SELECT dept.dname, count(*) FROM emp JOIN dept ON emp.did = dept.did GROUP BY dept.dname ORDER BY dept.dname
----
eng
2
sales
1

query TIIT nosort
SELECT dept.dname, count(*), sum(emp.eid), min(emp.ename) FROM emp JOIN dept ON emp.did = dept.did GROUP BY dept.dname ORDER BY dept.dname
----
eng
2
21
ann
sales
1
12
cy

query T nosort
SELECT dept.dname FROM emp JOIN dept ON emp.did = dept.did GROUP BY dept.dname HAVING count(*) > 1 ORDER BY dept.dname
----
eng

query II nosort
SELECT count(DISTINCT dept.dname), count(DISTINCT emp.did) FROM emp JOIN dept ON emp.did = dept.did
----
2
2

# ORDER BY an aggregate, over a join.
query TI nosort
SELECT dname, count(*) FROM emp JOIN dept ON emp.did = dept.did GROUP BY dname ORDER BY count(*) DESC, dname
----
eng
2
sales
1

# WHERE runs before the grouping, as always — it just sees the joined row now.
query TI nosort
SELECT dept.dname, count(*) FROM emp JOIN dept ON emp.did = dept.did WHERE emp.eid > 10 GROUP BY dept.dname ORDER BY dept.dname
----
eng
1
sales
1

# A bare aggregate over an empty join result is still ONE row.
query I nosort
SELECT count(*) FROM emp JOIN dept ON emp.did = dept.did WHERE dept.dname = 'zzz'
----
0

# `GROUP BY dept.did` — a QUALIFIED group key. It did not parse at all before
# joins existed (GROUP BY took a bare name), and over a join it is the only
# way to say which `did` you mean.
query II nosort
SELECT dept.did, count(*) FROM emp JOIN dept ON emp.did = dept.did GROUP BY dept.did ORDER BY dept.did
----
1
2
2
1

# And the ambiguity is still an error, not a guess.
statement error ambiguous
SELECT did, count(*) FROM emp JOIN dept ON emp.did = dept.did GROUP BY did

# ---- EXPLAIN tells the truth about the cost -----------------------------------------
# The footprint reads 0x3 — one bit per table. A join that claimed only the
# outer would under-claim `tables_read`, and `conflicts_with` is a bitmap AND,
# so a writer to `dept` would not be seen to conflict with this reader.
#
# Since #49 the equality `emp.did = dept.did` is CONSUMED into the inner
# fetch: dept.did is dept's whole PK, so each outer row does one PkPoint get
# instead of pairing with a held full scan. The residual ON is `true` — the
# equality was the entire condition, and EXPLAIN says where it went.

query T nosort
EXPLAIN SELECT emp.ename FROM emp JOIN dept ON emp.did = dept.did
----
Select emp
  access: FullScan
  inner join dept (index nested loop — ON equality pushed into the inner fetch)
    access: PkPoint(did = emp.did)
    on: true
  project: emp.ename
  footprint: read_only=true tables_read=0x3 tables_written=0x0 indexes_used=0x1 key=Full

# An ON with no equality still reads the inner side once and holds it — the
# pre-pushdown execution, with the honest O(n*m) label.
query T nosort
EXPLAIN SELECT emp.ename FROM emp JOIN dept ON emp.did > dept.did
----
Select emp
  access: FullScan
  inner join dept (nested loop, O(n*m) — no predicate pushdown)
    access: FullScan
    on: emp.did > dept.did
  project: emp.ename
  footprint: read_only=true tables_read=0x3 tables_written=0x0 indexes_used=0x1 key=Full

# ---- #65: WHERE pushdown into the chain -----------------------------------------------
# A comma-join's WHERE equality is consumed exactly like an ON equality: the
# inner fetch becomes a PK probe, and single-table conjuncts prune their own
# step. Differential: sqlite must agree on every row.

query TT nosort
SELECT emp.ename, dept.dname FROM emp, dept WHERE emp.did = dept.did AND dept.dname = 'eng' ORDER BY 1
----
ann
eng
bob
eng

query T nosort
EXPLAIN SELECT emp.ename FROM emp, dept WHERE emp.did = dept.did
----
Select emp
  access: FullScan
  inner join dept (index nested loop — ON equality pushed into the inner fetch)
    access: PkPoint(did = emp.did)
    on: true
  project: emp.ename
  footprint: read_only=true tables_read=0x3 tables_written=0x0 indexes_used=0x1 key=Full

# The NULL-extension boundary: a WHERE conjunct on a LEFT join's inner side
# filters the NULL-EXTENDED row (it stays in joined_filter); pushing it into
# the ON would decide MATCHING instead and resurrect the unmatched rows.
# sqlite is the referee for both shapes.

query TT nosort
SELECT emp.ename, dept.dname FROM emp LEFT JOIN dept ON emp.did = dept.did WHERE dept.dname = 'eng' ORDER BY 1
----
ann
eng
bob
eng

query T nosort
SELECT emp.ename FROM emp LEFT JOIN dept ON emp.did = dept.did WHERE dept.dname IS NULL
----
dee

# An outer-side conjunct DOES push past a LEFT join (every outer row
# survives the join, so pre-filtering removes whole groups, nothing else).
query TT nosort
SELECT emp.ename, dept.dname FROM emp LEFT JOIN dept ON emp.did = dept.did WHERE emp.eid = 13
----
dee
NULL
