# Non-unique secondary index (#48): `indexed = true` builds a lookup index
# that ALLOWS duplicates, and `WHERE cid = <v>` must return EVERY match
# through it.
#
# Expected values verified against sqlite3 3.45 with `CREATE INDEX t ON
# orders(cid)` — an index must never change an answer, only how it is found.
# Pinned because the first wiring of the planner picked the index and then
# probed it with an exact get against the composite `(value ‖ pk)` keys:
# `WHERE cid = ?` silently returned 0 rows.
#
# schema:
# [[table]]
# name = "orders"
# primary_key = ["oid"]
#
#   [[table.column]]
#   name = "oid"
#   type = "int64"
#
#   [[table.column]]
#   name = "cid"
#   type = "int64"
#   indexed = true
#
#   [[table.column]]
#   name = "note"
#   type = "text"
#   nullable = true
# end schema

statement ok
INSERT INTO orders (oid, cid, note) VALUES (1, 100, 'a'), (2, 100, 'b'), (3, 100, 'c'), (4, 200, 'd'), (5, 300, NULL)

# ---- the probe returns every match -------------------------------------------------

# Every duplicate comes back — not one of them, and not zero.
query I nosort
SELECT oid FROM orders WHERE cid = 100 ORDER BY oid
----
1
2
3

query I nosort
SELECT count(*) FROM orders WHERE cid = 100
----
3

# A value with no matches is empty, not an error.
query I nosort
SELECT oid FROM orders WHERE cid = 999
----

# `cid = NULL` is UNKNOWN — it matches nothing (NULLs are never indexed, and
# NULL equals nothing, not even NULL).
query I nosort
SELECT oid FROM orders WHERE cid = NULL
----

# ---- the rest of the surface composes over the probe -------------------------------

# The residual filter still applies on top of the index probe.
query I nosort
SELECT oid FROM orders WHERE cid = 100 AND note = 'b'
----
2

# LIMIT bounds the index matches like any other row source.
query I nosort
SELECT oid FROM orders WHERE cid = 100 ORDER BY oid DESC LIMIT 2
----
3
2

query I nosort
SELECT DISTINCT cid FROM orders WHERE cid = 100
----
100

query I nosort
SELECT sum(oid) FROM orders WHERE cid = 100
----
6

query T nosort
SELECT min(note) FROM orders WHERE cid = 100
----
a

query II nosort
SELECT cid, count(*) FROM orders WHERE cid = 100 GROUP BY cid
----
100
3

# A PK conjunct beside the index conjunct: the answer is the intersection no
# matter which access path the planner picks.
query I nosort
SELECT oid FROM orders WHERE oid > 1 AND cid = 100 ORDER BY oid
----
2
3

query I nosort
SELECT oid FROM orders WHERE cid IN (200, 300) ORDER BY oid
----
4
5

# ORDER BY a column the probe did not use.
query T nosort
SELECT note FROM orders WHERE cid = 100 ORDER BY note DESC
----
c
b
a

query I nosort
SELECT oid FROM orders WHERE cid = 100 AND note LIKE 'a%'
----
1

query I nosort
SELECT oid FROM orders WHERE cid = 300 AND note IS NULL
----
5

# ---- writes routed through the probe ------------------------------------------------

# UPDATE of a NON-indexed column, found via the index.
statement ok
UPDATE orders SET note = 'x' WHERE cid = 200

query T nosort
SELECT note FROM orders WHERE oid = 4
----
x

# Moving the INDEXED value itself exercises the old-key/new-key maintenance
# pair under the composite layout — every duplicate moves.
statement ok
UPDATE orders SET cid = 300 WHERE cid = 100

query I nosort
SELECT oid FROM orders WHERE cid = 100
----

query I nosort
SELECT oid FROM orders WHERE cid = 300 ORDER BY oid
----
1
2
3
5

query I nosort
SELECT count(*) FROM orders WHERE cid = 300
----
4

# The vacated value is immediately reusable.
statement ok
INSERT INTO orders (oid, cid, note) VALUES (6, 100, 'e')

query I nosort
SELECT oid FROM orders WHERE cid = 100
----
6

# DELETE with a residual on top of the probe removes exactly the matches.
statement ok
DELETE FROM orders WHERE cid = 300 AND note = 'b'

query I nosort
SELECT oid FROM orders WHERE cid = 300 ORDER BY oid
----
1
3
5

statement ok
DELETE FROM orders WHERE cid = 300

query I nosort
SELECT oid FROM orders ORDER BY oid
----
4
6

query I nosort
SELECT oid FROM orders WHERE cid = 200
----
4

query I nosort
SELECT oid FROM orders WHERE cid = 100
----
6

# ---- what is refused ----------------------------------------------------------------

# ON CONFLICT cannot probe a non-unique index — there is no single row to have
# conflicted with. Refused at prepare, like PostgreSQL.
statement error UNIQUE
INSERT INTO orders (oid, cid, note) VALUES (9, 200, 'x') ON CONFLICT (cid) DO UPDATE SET note = excluded.note

# Duplicates keep working after the delete/insert churn above.
statement ok
INSERT INTO orders (oid, cid, note) VALUES (7, 100, 'g')

query I nosort
SELECT count(*) FROM orders WHERE cid = 100
----
2

# Full PK pinning wins over the index probe; the answer is the same row either way.
query I nosort
SELECT oid FROM orders WHERE cid = 100 AND oid = 7
----
7
