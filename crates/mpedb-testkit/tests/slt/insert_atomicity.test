# Statement atomicity in autocommit mode: a multi-row INSERT (or multi-row
# UPDATE) that fails part-way leaves NOTHING behind -- the autocommit
# transaction is rolled back wholesale. Also: bind-time failures never
# execute at all, and NULLs never collide in UNIQUE indexes.
#
# schema:
# [[table]]
# name = "t"
# primary_key = ["id"]
#
#   [[table.column]]
#   name = "id"
#   type = "int64"
#
#   [[table.column]]
#   name = "v"
#   type = "int64"
#   check = "v >= 0"
#
#   [[table.column]]
#   name = "u"
#   type = "text"
#   unique = true
# end schema

# Internal PK duplicate on the third row: rows one and two must vanish too.
statement error PRIMARY KEY
INSERT INTO t (id, v, u) VALUES (1, 1, 'a'), (2, 2, 'b'), (1, 3, 'c')

query I nosort
SELECT id FROM t
----

# CHECK violation on the third row: same story.
statement error CHECK
INSERT INTO t (id, v, u) VALUES (1, 1, 'a'), (2, 2, 'b'), (3, -5, 'c')

query I nosort
SELECT id FROM t
----

# Internal UNIQUE collision between the batch's own rows.
statement error UNIQUE
INSERT INTO t (id, v, u) VALUES (1, 1, 'x'), (2, 2, 'x')

query I nosort
SELECT id FROM t
----

# A bind-time type error means nothing even started executing.
statement error cannot be inserted
INSERT INTO t (id, v, u) VALUES (1, 1, 'a'), (2, 'x', 'b')

query I nosort
SELECT id FROM t
----

# A fully valid multi-row insert lands atomically.
statement ok
INSERT INTO t (id, v, u) VALUES (1, 10, 'a'), (2, 20, 'b'), (3, 30, 'c'), (4, 40, 'd'), (5, 0, 'e')

query II nosort
SELECT id, v FROM t
----
1
10
2
20
3
30
4
40
5
0

# Collision with a PRE-EXISTING row in the middle of a batch: the rows
# before AND after the collision are both rolled back.
statement error PRIMARY KEY
INSERT INTO t (id, v, u) VALUES (6, 60, 'f'), (3, 99, 'zz'), (7, 70, 'g')

query I nosort
SELECT id FROM t
----
1
2
3
4
5

statement error UNIQUE
INSERT INTO t (id, v, u) VALUES (6, 60, 'f'), (7, 70, 'a')

query I nosort
SELECT id FROM t
----
1
2
3
4
5

# Single-row constraint failure leaves nothing either.
statement error CHECK
INSERT INTO t (id, v, u) VALUES (9, -1, NULL)

query I nosort
SELECT id FROM t WHERE id = 9
----

# Multiple NULLs in a UNIQUE column are fine -- even inside one batch.
statement ok
INSERT INTO t (id, v, u) VALUES (10, 1, NULL), (11, 1, NULL)

query I nosort
SELECT id FROM t WHERE u IS NULL
----
10
11

# ---- multi-row UPDATE atomicity ----------------------------------------------------

# v = v - 2 drives id 5 (v=0) below the CHECK: every already-updated row
# must roll back with it.
statement error CHECK
UPDATE t SET v = v - 2

query II nosort
SELECT id, v FROM t
----
1
10
2
20
3
30
4
40
5
0
10
1
11
1

statement error UNIQUE
UPDATE t SET u = 'a' WHERE id = 2

query T nosort
SELECT u FROM t WHERE id = 2
----
b

# A valid whole-table UPDATE applies to every row.
statement ok
UPDATE t SET v = v + 1

query II nosort
SELECT id, v FROM t
----
1
11
2
21
3
31
4
41
5
1
10
2
11
2

statement error CHECK
UPDATE t SET v = v - 100 WHERE id = 1

query I nosort
SELECT v FROM t WHERE id = 1
----
11

# Internal duplicate inside one batch (same key twice).
statement error PRIMARY KEY
INSERT INTO t (id, v, u) VALUES (12, 1, 'l'), (12, 2, 'm')

query I nosort
SELECT id FROM t WHERE id = 12
----

# Delete + reinsert of the same key inside consecutive statements works.
statement ok
DELETE FROM t WHERE id = 11

statement ok
INSERT INTO t (id, v, u) VALUES (11, 5, 'k')

query I nosort
SELECT v FROM t WHERE id = 11
----
5

statement ok
INSERT INTO t (id, v, u) VALUES (20, 1, 'p'), (21, 2, 'q'), (22, 3, 'r'), (23, 4, 'ss'), (24, 5, 'tt'), (25, 6, 'uu')

query I nosort
SELECT id FROM t WHERE id >= 20
----
20
21
22
23
24
25

# Failure on the LAST row of a batch: the first two still vanish.
statement error CHECK
INSERT INTO t (id, v, u) VALUES (30, 1, NULL), (31, 1, NULL), (32, -9, NULL)

query I nosort
SELECT id FROM t WHERE id >= 30
----
