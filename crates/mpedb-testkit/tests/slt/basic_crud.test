# Basic CRUD: INSERT / SELECT / UPDATE / DELETE round trips, column lists,
# quoted identifiers, string escapes. Executable documentation of the core
# statement semantics.
#
# schema:
# [[table]]
# name = "users"
# primary_key = ["id"]
#
#   [[table.column]]
#   name = "id"
#   type = "int64"
#
#   [[table.column]]
#   name = "name"
#   type = "text"
#   nullable = false
#
#   [[table.column]]
#   name = "age"
#   type = "int64"
#
#   [[table.column]]
#   name = "active"
#   type = "bool"
# end schema

# A fresh table is empty.
query ITIT nosort
SELECT * FROM users
----

statement ok
INSERT INTO users (id, name, age, active) VALUES (1, 'alice', 34, true)

statement ok
INSERT INTO users (id, name, age, active) VALUES (2, 'bob', 19, false)

statement ok
INSERT INTO users (id, name, age, active) VALUES (3, 'carol', NULL, true)

statement ok
INSERT INTO users (id, name, age, active) VALUES (4, 'dave', 27, NULL)

# Multi-row insert.
statement ok
INSERT INTO users (id, name, age, active) VALUES (5, 'eve', 41, true), (6, 'frank', 8, false)

# Full scan returns primary-key order.
query ITIT nosort
SELECT * FROM users
----
1
alice
34
true
2
bob
19
false
3
carol
NULL
true
4
dave
27
NULL
5
eve
41
true
6
frank
8
false

# Point lookup by primary key.
query T nosort
SELECT name FROM users WHERE id = 3
----
carol

query I nosort
SELECT id FROM users WHERE name = 'dave'
----
4

# Projection expressions.
query II nosort
SELECT id, age + 1 FROM users WHERE id = 1
----
1
35

query I nosort
SELECT id * 10 - 1 FROM users WHERE id = 2
----
19

# A bare bool column is a valid predicate; NULL does not pass.
query I nosort
SELECT id FROM users WHERE active
----
1
3
5

query I nosort
SELECT id FROM users WHERE NOT active
----
2
6

query I nosort
SELECT id FROM users WHERE age >= 20 AND age < 40
----
1
4

# Text comparison is bytewise (binary collation).
query I nosort
SELECT id FROM users WHERE name < 'c'
----
1
2

statement ok
UPDATE users SET age = 20 WHERE id = 2

query I nosort
SELECT age FROM users WHERE id = 2
----
20

# NULL age (id 3) is not >= 20: not updated.
statement ok
UPDATE users SET active = true WHERE age >= 20

query I nosort
SELECT id FROM users WHERE active
----
1
2
3
4
5

# UPDATE matching nothing succeeds and changes nothing.
statement ok
UPDATE users SET age = 0 WHERE id = 99

query I nosort
SELECT id FROM users WHERE age = 0
----

statement ok
DELETE FROM users WHERE id = 6

query I nosort
SELECT id FROM users
----
1
2
3
4
5

# DELETE matching nothing succeeds.
statement ok
DELETE FROM users WHERE id = 42

query I nosort
SELECT id FROM users
----
1
2
3
4
5

# Column list in any order; omitted nullable columns default to NULL.
statement ok
INSERT INTO users (name, id) VALUES ('zoe', 7)

query ITIT nosort
SELECT * FROM users WHERE id = 7
----
7
zoe
NULL
NULL

# No column list = all columns in declaration order.
statement ok
INSERT INTO users VALUES (8, 'hank', 30, true)

query ITIT nosort
SELECT * FROM users WHERE id = 8
----
8
hank
30
true

# Quoted identifiers.
query I nosort
SELECT "id" FROM users WHERE "name" = 'hank'
----
8

# '' escapes a quote inside string literals.
statement ok
INSERT INTO users (id, name) VALUES (9, 'it''s')

query T nosort
SELECT name FROM users WHERE id = 9
----
it's

query I nosort
SELECT id FROM users WHERE name LIKE 'z%'
----
7

# Unqualified DELETE clears the table.
statement ok
DELETE FROM users

query I nosort
SELECT id FROM users
----
