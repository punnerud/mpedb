# Constraint enforcement: PRIMARY KEY, UNIQUE (secondary index), NOT NULL,
# and CHECK. Failed statements leave the database untouched (autocommit
# statements are transactions). NULL passes CHECK (SQL standard: only FALSE
# violates) and NULLs never collide in a UNIQUE index.
#
# schema:
# [[table]]
# name = "users"
# primary_key = ["id"]
#
#   [[table.column]]
#   name = "id"
#   type = "int64"
#
#   [[table.column]]
#   name = "email"
#   type = "text"
#   nullable = false
#   unique = true
#
#   [[table.column]]
#   name = "age"
#   type = "int64"
#   check = "age >= 0 AND age < 200"
#
#   [[table.column]]
#   name = "nick"
#   type = "text"
#   unique = true
# end schema

statement ok
INSERT INTO users (id, email, age, nick) VALUES (1, 'a@x', 30, 'al')

# CHECK boundaries: 0 and 199 are inside.
statement ok
INSERT INTO users (id, email, age, nick) VALUES (2, 'b@x', 0, 'bo')

statement ok
INSERT INTO users (id, email, age, nick) VALUES (3, 'c@x', 199, NULL)

# ---- PRIMARY KEY -------------------------------------------------------------

statement error PRIMARY KEY
INSERT INTO users (id, email, age, nick) VALUES (1, 'z@x', 10, NULL)

# The failed insert changed nothing.
query T nosort
SELECT email FROM users WHERE id = 1
----
a@x

# ---- UNIQUE -------------------------------------------------------------------

statement error UNIQUE
INSERT INTO users (id, email, age, nick) VALUES (4, 'a@x', 10, NULL)

query I nosort
SELECT id FROM users WHERE id = 4
----

statement error UNIQUE
INSERT INTO users (id, email, age, nick) VALUES (4, 'd@x', 10, 'al')

# NULL never collides in a unique index.
statement ok
INSERT INTO users (id, email, age, nick) VALUES (4, 'd@x', 10, NULL)

statement ok
INSERT INTO users (id, email, age, nick) VALUES (5, 'e@x', NULL, NULL)

query I nosort
SELECT id FROM users WHERE nick IS NULL
----
3
4
5

# ---- CHECK ---------------------------------------------------------------------

# NULL age passes the CHECK (UNKNOWN is not a violation).
query I nosort
SELECT id FROM users WHERE age IS NULL
----
5

statement error CHECK
INSERT INTO users (id, email, age, nick) VALUES (6, 'f@x', -1, NULL)

statement error CHECK
INSERT INTO users (id, email, age, nick) VALUES (6, 'f@x', 200, NULL)

statement ok
INSERT INTO users (id, email, age, nick) VALUES (6, 'f@x', 199, 'fi')

query I nosort
SELECT id FROM users
----
1
2
3
4
5
6

# ---- NOT NULL ------------------------------------------------------------------

# Explicit NULL into a NOT NULL column is rejected at prepare time.
statement error NULL
INSERT INTO users (id, email, age, nick) VALUES (7, NULL, 10, NULL)

# Omitting a NOT NULL column without a default is rejected too.
statement error email
INSERT INTO users (id, age) VALUES (7, 10)

statement error NULL
UPDATE users SET email = NULL WHERE id = 1

# A NULL that only materializes at runtime (from another column) is caught
# by the engine.
statement error NOT NULL
UPDATE users SET email = nick WHERE id = 5

query T nosort
SELECT email FROM users WHERE id = 5
----
e@x

# ---- constraint violations via UPDATE ------------------------------------------

statement error UNIQUE
UPDATE users SET email = 'a@x' WHERE id = 2

query T nosort
SELECT email FROM users WHERE id = 2
----
b@x

# Setting a unique column to its current value is not a collision.
statement ok
UPDATE users SET email = 'b@x' WHERE id = 2

statement error CHECK
UPDATE users SET age = -5 WHERE id = 1

query I nosort
SELECT age FROM users WHERE id = 1
----
30

# Multi-row UPDATE hitting a CHECK violation mid-way rolls the whole
# statement back (id 2 has age 0; 0 - 100 violates).
statement error CHECK
UPDATE users SET age = age - 100

query I nosort
SELECT age FROM users
----
30
0
199
10
NULL
199

statement ok
UPDATE users SET age = age + 1 WHERE id = 2

query I nosort
SELECT age FROM users WHERE id = 2
----
1

statement error UNIQUE
UPDATE users SET nick = 'al' WHERE id = 2

# Releasing the nick makes it available again.
statement ok
UPDATE users SET nick = NULL WHERE id = 1

statement ok
INSERT INTO users (id, email, age, nick) VALUES (7, 'g@x', 10, 'al')

query I nosort
SELECT id FROM users WHERE nick = 'al'
----
7

statement error primary key
UPDATE users SET id = 99 WHERE id = 7

query T nosort
SELECT nick FROM users WHERE id = 7
----
al

# A single-column INTEGER PRIMARY KEY is a rowid alias (sqlite): a NULL id
# auto-assigns max(rowid)+1. The current max id is 7, so this row gets 8.
statement ok
INSERT INTO users (id, email) VALUES (NULL, 'h@x')

query I nosort
SELECT id FROM users WHERE email = 'h@x'
----
8

# ---- ON CONFLICT on a SECONDARY unique column ---------------------------------------
# The conflict target may name any key the executor can PROBE: the primary
# key, or one UNIQUE column. It has to find the row you collided with, and
# guessing ("you said (email), I will look up the PK anyway") would update a
# different row and report it as yours.
#
# Expected values come from running the same program through sqlite3 3.45.

# `a@x` already belongs to id 1. The proposed id 90 is never inserted — the
# EXISTING row is updated, which is the whole point of an upsert on a
# non-PK key.
statement ok
INSERT INTO users (id, email, age, nick) VALUES (90, 'a@x', 31, 'zz') ON CONFLICT (email) DO UPDATE SET age = excluded.age

query II nosort
SELECT id, age FROM users WHERE email = 'a@x'
----
1
31

# The row is still id 1: id 90 did not enter.
query I nosort
SELECT count(*) FROM users WHERE id = 90
----
0

# A second unique column works the same way, and the SET sees both rows:
# `users.age` is the existing 1, `excluded.age` the proposed 5.
statement ok
INSERT INTO users (id, email, age, nick) VALUES (91, 'q@x', 5, 'bo') ON CONFLICT (nick) DO UPDATE SET age = users.age + excluded.age

query II nosort
SELECT id, age FROM users WHERE nick = 'bo'
----
2
6

# A WHERE on the update: NULL and FALSE both skip, SQL needs exactly TRUE.
statement ok
INSERT INTO users (id, email, age, nick) VALUES (92, 'a@x', 77, 'yy') ON CONFLICT (email) DO UPDATE SET age = excluded.age WHERE users.age > 100

query II nosort
SELECT id, age FROM users WHERE email = 'a@x'
----
1
31

# No conflict at all: the row just inserts.
statement ok
INSERT INTO users (id, email, age, nick) VALUES (10, 'new@x', 20, 'nw') ON CONFLICT (email) DO UPDATE SET age = excluded.age

query ITI nosort
SELECT id, email, age FROM users WHERE id = 10
----
10
new@x
20

# RETURNING reports the row that was actually touched — id 2, not the 93 that
# was proposed and never existed.
query II nosort
INSERT INTO users (id, email, age, nick) VALUES (93, 'b@x', 1, 'rr') ON CONFLICT (email) DO UPDATE SET age = 42 RETURNING id, age
----
2
42

# ---- the conflict you named is the only one handled ---------------------------------
# Target (email), but it is the PK that collides. That is NOT the conflict the
# statement asked to handle, so it is an error — as in sqlite and PG. Silently
# upserting the email row would touch a row the caller never mentioned;
# silently doing nothing would hide a real collision.

statement error PRIMARY KEY
INSERT INTO users (id, email, age, nick) VALUES (1, 'brand-new@x', 12, NULL) ON CONFLICT (email) DO UPDATE SET age = excluded.age

# Unchanged.
query I nosort
SELECT age FROM users WHERE id = 1
----
31

# And the mirror case: target (id), but the EMAIL is what collides.
statement error UNIQUE
INSERT INTO users (id, email, age, nick) VALUES (77, 'a@x', 12, NULL) ON CONFLICT (id) DO UPDATE SET age = excluded.age

# A target that is neither the PK nor a single UNIQUE column has no key to
# probe by, and the message says which ones would work.
statement error must be a key
INSERT INTO users (id, email, age, nick) VALUES (78, 'p@x', 12, NULL) ON CONFLICT (age) DO UPDATE SET age = excluded.age

# "Unique together" is not something the schema can declare, so a multi-column
# non-PK target has no index either — even though each column is unique alone.
statement error must be a key
INSERT INTO users (id, email, age, nick) VALUES (79, 'r@x', 12, NULL) ON CONFLICT (email, nick) DO UPDATE SET age = excluded.age
