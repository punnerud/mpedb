# FROM-less SELECT (#67, PLAN_FORMAT 10): `SELECT 3+5` reads no table and
# evaluates over ONE synthetic empty row — sqlite/PG semantics. WHERE still
# filters that row; aggregates aggregate it (count(*) = 1); compound arms and
# scalar subqueries may each be FROM-less. The footprint is empty and the
# plan conflicts with nothing.
#
# schema:
# [[table]]
# name = "t"
# primary_key = ["id"]
#
#   [[table.column]]
#   name = "id"
#   type = "int64"
#
#   [[table.column]]
#   name = "a"
#   type = "int64"
# end schema

statement ok
INSERT INTO t (id, a) VALUES (1, 10)

statement ok
INSERT INTO t (id, a) VALUES (2, 20)

# ---- the basic forms ------------------------------------------------------------------

query I nosort
SELECT 3+5
----
8

query III nosort
SELECT 3, 5, 3*5
----
3
5
15

query T nosort
SELECT 'a' || 'b'
----
ab

query I nosort
SELECT CAST(3 AS INTEGER) + 5
----
8

query I nosort
SELECT -2 + +7
----
5

# NULL arithmetic stays NULL over the dual row too.
query I nosort
SELECT NULL + 1
----
NULL

query I nosort
SELECT CASE WHEN 1=1 THEN 42 ELSE 7 END
----
42

# ---- WHERE filters the one synthetic row ----------------------------------------------
# (bool-typed predicates: `WHERE 1` is refused by rigid typing — the
# documented deviation applies FROM-less too.)

query I nosort
SELECT 3 WHERE 1=1
----
3

query I nosort
SELECT 3 WHERE 1=0
----

query I nosort
SELECT 3 WHERE NULL = 1
----

# ---- aggregates over the one-row relation ---------------------------------------------

query I nosort
SELECT count(*)
----
1

query I nosort
SELECT sum(5)
----
5

query II nosort
SELECT min(3), max(3)
----
3
3

# ---- DISTINCT / LIMIT / ORDER BY ordinals ---------------------------------------------

query I nosort
SELECT DISTINCT 1
----
1

query I nosort
SELECT 3 LIMIT 0
----

query I nosort
SELECT 3 ORDER BY 1
----
3

# ---- compound arms may be FROM-less, mixed with table arms ----------------------------

query I nosort
SELECT 1 UNION SELECT 2 UNION SELECT 1
----
1
2

query I nosort
SELECT 15 UNION SELECT a FROM t ORDER BY 1
----
10
15
20

query I nosort
SELECT a FROM t EXCEPT SELECT 10
----
20

# ---- subqueries: FROM-less inner, FROM-less outer, both ------------------------------

query I nosort
SELECT (SELECT 3)
----
3

query I nosort
SELECT (SELECT max(a) FROM t)
----
20

query I nosort
SELECT a FROM t WHERE EXISTS (SELECT 1) ORDER BY a
----
10
20

query I nosort
SELECT a FROM t WHERE a = (SELECT 20)
----
20

# ---- aliases name the output ----------------------------------------------------------

query I nosort
SELECT 3+5 AS answer
----
8

query I nosort
SELECT 3+5 answer
----
8

# ---- floats, text, NULL-handling functions --------------------------------------------

query R nosort
SELECT 1.5 * 2.0
----
3.000

query T nosort
SELECT upper('abc')
----
ABC

query I nosort
SELECT length('abcd')
----
4

query I nosort
SELECT coalesce(NULL, NULL, 7)
----
7

query I nosort
SELECT abs(-42)
----
42

query T nosort
SELECT substr('abcdef', 2, 3)
----
bcd

query I nosort
SELECT CASE WHEN NULL = 1 THEN 1 ELSE 2 END
----
2

query I nosort
SELECT CASE WHEN 5 BETWEEN 1 AND 9 THEN 1 ELSE 0 END
----
1

query I nosort
SELECT CASE WHEN 3 IN (1, 2, 3) THEN 1 ELSE 0 END
----
1
