# SQL three-valued logic: comparisons and arithmetic with NULL yield NULL,
# AND/OR/NOT follow Kleene logic, and a WHERE filter passes only on exactly
# TRUE (UNKNOWN filters the row out).
#
# schema:
# [[table]]
# name = "t"
# primary_key = ["id"]
#
#   [[table.column]]
#   name = "id"
#   type = "int64"
#
#   [[table.column]]
#   name = "a"
#   type = "int64"
#
#   [[table.column]]
#   name = "b"
#   type = "bool"
#
#   [[table.column]]
#   name = "s"
#   type = "text"
# end schema

statement ok
INSERT INTO t (id, a, b, s) VALUES (1, 10, true, 'x')

statement ok
INSERT INTO t (id, a, b, s) VALUES (2, NULL, false, NULL)

statement ok
INSERT INTO t (id, a, b, s) VALUES (3, 0, NULL, 'y')

statement ok
INSERT INTO t (id, a, b, s) VALUES (4, -5, true, NULL)

# ---- `= NULL` matches nothing (UNKNOWN, not equality) --------------------------

query I nosort
SELECT id FROM t WHERE a = NULL
----

query I nosort
SELECT id FROM t WHERE a <> NULL
----

# NOT(UNKNOWN) is still UNKNOWN.
query I nosort
SELECT id FROM t WHERE NOT (a = NULL)
----

query I nosort
SELECT id FROM t WHERE a > NULL
----

query I nosort
SELECT id FROM t WHERE NOT (a > NULL)
----

query I nosort
SELECT id FROM t WHERE a = 10
----
1

# ---- IS NULL / IS NOT NULL are two-valued ---------------------------------------

query I nosort
SELECT id FROM t WHERE a IS NULL
----
2

query I nosort
SELECT id FROM t WHERE a IS NOT NULL
----
1
3
4

query I nosort
SELECT id FROM t WHERE NULL IS NULL
----
1
2
3
4

query I nosort
SELECT id FROM t WHERE NOT (NULL IS NULL)
----

# IS NULL applies to expressions, not just columns.
query I nosort
SELECT id FROM t WHERE a + 1 IS NULL
----
2

query I nosort
SELECT id FROM t WHERE (NULL + 1) IS NULL
----
1
2
3
4

# ---- NULL propagates through arithmetic ------------------------------------------

query II nosort
SELECT id, a + 1 FROM t
----
1
11
2
NULL
3
1
4
-4

query II nosort
SELECT id, a * 0 FROM t
----
1
0
2
NULL
3
0
4
0

query II nosort
SELECT id, a + NULL FROM t
----
1
NULL
2
NULL
3
NULL
4
NULL

query II nosort
SELECT id, a - a FROM t
----
1
0
2
NULL
3
0
4
0

query II nosort
SELECT id, -a FROM t
----
1
-10
2
NULL
3
0
4
5

# ---- Kleene AND / OR ---------------------------------------------------------------

# true AND UNKNOWN = UNKNOWN (row 1 passes only because a > 0 is TRUE there).
query I nosort
SELECT id FROM t WHERE b AND a > 0
----
1

# false OR UNKNOWN = UNKNOWN; true OR anything = TRUE.
query I nosort
SELECT id FROM t WHERE b OR a > 0
----
1
4

# Not a tautology under 3VL: the NULL row satisfies neither side.
query I nosort
SELECT id FROM t WHERE (a > 0) OR (a <= 0)
----
1
3
4

query I nosort
SELECT id FROM t WHERE NOT b
----
2

query I nosort
SELECT id FROM t WHERE b = false
----
2

query I nosort
SELECT id FROM t WHERE b <> true
----
2

query I nosort
SELECT id FROM t WHERE b IS NULL
----
3

# (b AND NULL) is UNKNOWN unless b is FALSE (false AND x = false).
query I nosort
SELECT id FROM t WHERE (b AND NULL) IS NULL
----
1
3
4

# (b OR NULL) is UNKNOWN unless b is TRUE (true OR x = true).
query I nosort
SELECT id FROM t WHERE (b OR NULL) IS NULL
----
2
3

query I nosort
SELECT id FROM t WHERE (s = 'x') OR (s = 'y')
----
1
3

query I nosort
SELECT id FROM t WHERE s IS NULL
----
2
4

# ---- NULL in DML --------------------------------------------------------------------

statement ok
UPDATE t SET a = NULL WHERE id = 1

query I nosort
SELECT id FROM t WHERE a IS NULL
----
1
2

# UPDATE/DELETE with an UNKNOWN predicate touch nothing.
statement ok
UPDATE t SET a = 77 WHERE a = NULL

query I nosort
SELECT id FROM t WHERE a = 77
----

statement ok
DELETE FROM t WHERE a = NULL

query I nosort
SELECT id FROM t
----
1
2
3
4
